# URL base da API do backend (apps/api)
VITE_API_URL=http://localhost:3000

# Login com Google (T-126). Client id OAuth do Google Cloud Console (tipo "Web
# application"), o MESMO valor do GOOGLE_CLIENT_ID da API. Vazio/ausente = o botão
# "Entrar com Google" não aparece e o produto segue só com e-mail e senha.
VITE_GOOGLE_CLIENT_ID=
