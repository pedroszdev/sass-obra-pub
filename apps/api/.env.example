# API
PORT=3000

# PostgreSQL (alinhar com docker-compose.yml)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=obrapub
DATABASE_PASSWORD=obrapub
DATABASE_NAME=obrapub

# JWT (use segredos longos e aleatórios em produção; nunca commite os reais)
JWT_ACCESS_SECRET=troque-este-segredo-de-access
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_REFRESH_EXPIRES=7d

# Captação (job de sincronização)
CAPTACAO_BACKFILL_DAYS=30
CAPTACAO_OVERLAP_DAYS=2
