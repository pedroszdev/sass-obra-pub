# API
PORT=3000

# PostgreSQL (alinhar com docker-compose.yml)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=obrapub
DATABASE_PASSWORD=obrapub
DATABASE_NAME=obrapub

# JWT (use segredos longos e aleatórios em produção; nunca commite os reais)
JWT_ACCESS_SECRET=troque-este-segredo-de-access
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_REFRESH_EXPIRES=7d

# Captação (job de sincronização)
CAPTACAO_BACKFILL_DAYS=30
CAPTACAO_OVERLAP_DAYS=2

# IA — extração de exigências de habilitação (Épico 5, T-49). Provider: OpenAI
# (ver CLAUDE.md §3.4). Sem OPENAI_API_KEY, a extração fica desabilitada (503).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Pré-computação em background na captação (T-54): a região já vem com resumo/
# exigências conforme é captada. LIGADA por padrão; PRECOMPUTE_ENABLED=false é o
# kill-switch de custo. PRECOMPUTE_LIMIT = teto de editais por disparo (por UF).
PRECOMPUTE_ENABLED=true
PRECOMPUTE_LIMIT=20

# E-mail transacional (T-101). SMTP vendor-agnostic — aponte para o provedor que
# quiser (SES, Resend, Postmark, Mailtrap em dev...). SEM SMTP_HOST → log-only (o
# e-mail é só logado, não enviado). MAIL_FROM precisa de domínio verificado no
# provedor para não cair em spam. NUNCA commite SMTP_USER/SMTP_PASS reais.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=PrumoLicita <nao-responda@seu-dominio.com.br>

# Teto de custo de IA (T-133, opcionais). Ausente/0 = sem teto.
IA_BUDGET_DAILY_USD=
IA_BUDGET_MONTHLY_USD=

# Cobrança — Stripe (T-128/T-129/T-131). AUSENTES → cobrança responde 503 e o
# resto do produto segue inteiro (mesma degradação da IA/Google/e-mail).
#
# Use a chave RESTRITA (rk_), não a secreta (sk_): escrita em Customers, Checkout
# Sessions, Subscriptions e Billing Portal Sessions; LEITURA em Prices, Invoices e
# Payment Methods (a tela de assinatura lê preços, faturas e o cartão).
STRIPE_SECRET_KEY=
# Os dois planos (T-131). O price_... vem do Dashboard; o VALOR mora lá, nunca
# aqui — preço escrito do nosso lado divergiria do que a Stripe cobra de fato.
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_ANUAL=
# Assinatura do webhook. É ela que autentica a Stripe (não há JWT nosso), e é o
# webhook — não o success_url — que marca alguém como pago.
STRIPE_WEBHOOK_SECRET=
